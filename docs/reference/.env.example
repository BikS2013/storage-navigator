# storage-nav agent — environment variable reference
# Copy/rename to ~/.tool-agents/storage-nav/.env and set values (mode 0600).
# Policy B (file-wins): values here always override matching shell exports.
# Do NOT commit this file with real values.

# ── Global agent settings ───────────────────────────────────────────────────
# Required: choose one of the six providers below
# STORAGE_NAV_AGENT_PROVIDER=azure-openai

# Required: model id or deployment name
# STORAGE_NAV_AGENT_MODEL=gpt-4o

# Optional: max ReAct iterations (default: 20)
# STORAGE_NAV_AGENT_MAX_STEPS=20

# Optional: sampling temperature (default: 0)
# STORAGE_NAV_AGENT_TEMPERATURE=0

# Optional: per-tool result byte cap (default: 16384 = 16 KiB)
# STORAGE_NAV_AGENT_PER_TOOL_BUDGET_BYTES=16384

# Optional: enable state-changing tools (default: false)
# STORAGE_NAV_AGENT_ALLOW_MUTATIONS=false

# Optional: comma-separated tool allowlist (default: all read-only tools)
# STORAGE_NAV_AGENT_TOOLS=list_blobs,view_blob,list_containers

# Optional: verbose per-step trace to stderr (default: false)
# STORAGE_NAV_AGENT_VERBOSE=false

# Optional: inline system prompt override
# STORAGE_NAV_AGENT_SYSTEM_PROMPT=

# Optional: path to system prompt file
# STORAGE_NAV_AGENT_SYSTEM_PROMPT_FILE=

# ── OpenAI (provider: openai) ───────────────────────────────────────────────
# Required: OPENAI_API_KEY
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
# OPENAI_ORG_ID=

# ── Anthropic (provider: anthropic) ────────────────────────────────────────
# Required: ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=

# ── Google Gemini (provider: gemini) ───────────────────────────────────────
# Required: GOOGLE_API_KEY or GEMINI_API_KEY (alias)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# ── Azure OpenAI (provider: azure-openai) — DEFAULT ───────────────────────
# Required: all three below
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Optional: defaults to 2024-10-21
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── Azure Anthropic / Foundry (provider: azure-anthropic) ─────────────────
# Required: AZURE_AI_INFERENCE_KEY, AZURE_AI_INFERENCE_ENDPOINT, and model via --model or STORAGE_NAV_AGENT_MODEL
# AZURE_AI_INFERENCE_KEY=
# AZURE_AI_INFERENCE_ENDPOINT=https://<resource>.services.ai.azure.com/
# AZURE_AI_INFERENCE_MODEL=claude-3-5-sonnet

# ── Local OpenAI-compatible (provider: local-openai) ──────────────────────
# Required: one of the following base URL vars
# LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_BASE_URL=http://localhost:11434/v1
# OLLAMA_HOST=http://localhost:11434
# OPENAI_API_KEY=not-needed  # optional; local servers often accept any string
