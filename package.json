{
  "name": "storage-navigator",
  "version": "1.0.0",
  "description": "Azure Blob Storage Navigator — CLI and Electron UI for browsing blob containers",
  "type": "module",
  "main": "dist/electron/main.js",
  "bin": {
    "storage-nav": "bin/storage-nav.mjs"
  },
  "scripts": {
    "build": "tsc",
    "cli": "npx tsx src/cli/index.ts",
    "ui": "npx tsx src/electron/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest"
  },
  "keywords": [
    "azure",
    "blob",
    "storage",
    "navigator",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@azure/storage-file-share": "^12.30.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "global-agent": "^4.1.3",
    "rimraf": "^6.1.3",
    "cacache": "^20.0.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.2",
    "esbuild": "^0.27.7",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
